{
  "$description": "Design tokens in W3C DTCG format. Portable source of truth; mirrors assets/tokens.css. Semantic color values shown for the light theme.",
  "color": {
    "$type": "color",
    "primitive": {
      "neutral": {
        "0":   { "$value": "#ffffff" },
        "50":  { "$value": "#f7f8fa" },
        "100": { "$value": "#eceef2" },
        "200": { "$value": "#d9dde3" },
        "300": { "$value": "#b9c0cb" },
        "400": { "$value": "#8b94a3" },
        "500": { "$value": "#5f6877" },
        "600": { "$value": "#444c59" },
        "700": { "$value": "#2d343f" },
        "800": { "$value": "#1b2027" },
        "900": { "$value": "#0e1116" }
      },
      "brand": {
        "50":  { "$value": "#eef4ff" },
        "100": { "$value": "#d9e6ff" },
        "300": { "$value": "#8fb4ff" },
        "500": { "$value": "#2563eb" },
        "600": { "$value": "#1d4ed8" },
        "700": { "$value": "#1740a8" }
      },
      "green": {
        "100": { "$value": "#dcfce7" },
        "600": { "$value": "#15803d" }
      },
      "amber": {
        "100": { "$value": "#fef3c7" },
        "600": { "$value": "#b45309" }
      },
      "red": {
        "100": { "$value": "#fee2e2" },
        "600": { "$value": "#dc2626" }
      }
    },
    "bg":         { "$value": "{color.primitive.neutral.0}",   "$description": "Page background" },
    "surface":    { "$value": "{color.primitive.neutral.50}",  "$description": "Cards, panels" },
    "fg":         { "$value": "{color.primitive.neutral.900}", "$description": "Primary text" },
    "muted-fg":   { "$value": "{color.primitive.neutral.500}", "$description": "Secondary text" },
    "border":     { "$value": "{color.primitive.neutral.200}", "$description": "Hairlines, dividers" },
    "primary":    { "$value": "{color.primitive.brand.600}" },
    "primary-fg": { "$value": "{color.primitive.neutral.0}",   "$description": "Text/icon on primary" },
    "success":    { "$value": "{color.primitive.green.600}" },
    "success-fg": { "$value": "{color.primitive.neutral.0}" },
    "warning":    { "$value": "{color.primitive.amber.600}" },
    "warning-fg": { "$value": "{color.primitive.neutral.0}" },
    "danger":     { "$value": "{color.primitive.red.600}" },
    "danger-fg":  { "$value": "{color.primitive.neutral.0}" }
  },
  "fontSize": {
    "$type": "dimension",
    "xs":   { "$value": "0.75rem" },
    "sm":   { "$value": "0.875rem" },
    "base": { "$value": "1rem" },
    "md":   { "$value": "1.25rem" },
    "lg":   { "$value": "1.5625rem" },
    "xl":   { "$value": "1.9375rem" },
    "2xl":  { "$value": "2.4375rem" },
    "3xl":  { "$value": "3.0625rem" }
  },
  "space": {
    "$type": "dimension",
    "1":  { "$value": "0.25rem" },
    "2":  { "$value": "0.5rem" },
    "3":  { "$value": "0.75rem" },
    "4":  { "$value": "1rem" },
    "5":  { "$value": "1.25rem" },
    "6":  { "$value": "1.5rem" },
    "8":  { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm":   { "$value": "0.25rem" },
    "md":   { "$value": "0.5rem" },
    "lg":   { "$value": "1rem" },
    "full": { "$value": "9999px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0", "color": "rgba(14, 17, 22, 0.08)" }
    },
    "md": {
      "$value": { "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "0", "color": "rgba(14, 17, 22, 0.12)" }
    },
    "lg": {
      "$value": { "offsetX": "0", "offsetY": "12px", "blur": "32px", "spread": "0", "color": "rgba(14, 17, 22, 0.18)" }
    }
  },
  "duration": {
    "$type": "duration",
    "fast": { "$value": "120ms" },
    "base": { "$value": "200ms" },
    "slow": { "$value": "320ms" }
  },
  "ease": {
    "$type": "cubicBezier",
    "standard":   { "$value": [0.2, 0, 0, 1] },
    "emphasized": { "$value": [0.3, 0, 0, 1] }
  },
  "zIndex": {
    "$type": "number",
    "dropdown": { "$value": 1000 },
    "modal":    { "$value": 1300 }
  },
  "breakpoint": {
    "$type": "dimension",
    "sm": { "$value": "640px" },
    "md": { "$value": "768px" },
    "lg": { "$value": "1024px" },
    "xl": { "$value": "1280px" }
  }
}
